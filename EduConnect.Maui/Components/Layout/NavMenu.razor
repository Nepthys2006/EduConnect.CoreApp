@code {
    private string GetActive(string href)
    {
        var nav = NavigationManager.Uri;
        if (string.IsNullOrEmpty(href) && (nav.EndsWith("/") || nav.EndsWith("/home")))
            return "active";
        if (!string.IsNullOrEmpty(href) && nav.Contains($"/{href}"))
            return "active";
        return "";
    }

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}

