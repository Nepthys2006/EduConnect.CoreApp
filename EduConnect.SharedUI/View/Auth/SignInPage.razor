@page "/signin"
@layout EduConnect.SharedUI.View.Auth.AuthLayout
@using EduConnect.SharedUI.Services
@inject IAuthService AuthService
@inject NavigationManager Nav

<div class="auth-card">
    <div class="auth-logo">
        <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#2563EB" stroke-width="1.5">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
        </svg>
    </div>
    <h1 class="auth-title">Sign In</h1>
    <p class="auth-subtitle">Enter your Gmail credentials to access your classroom</p>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="auth-error">@_error</div>
    }

    <div class="auth-form">
        <div class="auth-field">
            <label class="auth-label" for="email">Gmail Address</label>
            <div class="auth-input-wrap">
                <svg class="auth-input-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <input id="email" type="email" class="ec-input auth-input" placeholder="username@gmail.com"
                       @bind="_email" @bind:event="oninput" aria-label="Gmail address" />
            </div>
            <span class="auth-helper">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                Strictly @@gmail.com or @@deped.gov.ph addresses only.
            </span>
        </div>

        <div class="auth-field">
            <div class="auth-label-row">
                <label class="auth-label" for="password">Password</label>
                <a class="auth-link-inline" href="#">Forgot password?</a>
            </div>
            <div class="auth-input-wrap">
                <svg class="auth-input-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <input id="password" type="password" class="ec-input auth-input" placeholder="••••••••"
                       @bind="_password" @bind:event="oninput" @onkeydown="HandleKeyDown" aria-label="Password" />
            </div>
        </div>

        <div class="auth-info-banner">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>This portal is restricted to authenticated educational users. Unauthorized access attempts are logged.</span>
        </div>

        <button class="ec-btn ec-btn-primary auth-submit" @onclick="HandleLogin" disabled="@_loading">
            @if (_loading) { <span class="auth-spinner"></span> }
            Sign In
        </button>

        <p class="auth-footer-text">Don't have an account?</p>
        <button class="ec-btn ec-btn-secondary auth-create-link" @onclick="GoToCreate">
            Create an account
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please fill in all fields.";
            return;
        }
        if (!_email.EndsWith("@gmail.com", StringComparison.OrdinalIgnoreCase) &&
            !_email.EndsWith("@deped.gov.ph", StringComparison.OrdinalIgnoreCase))
        {
            _error = "Only @gmail.com or @deped.gov.ph addresses are accepted.";
            return;
        }

        _loading = true;
        var success = await AuthService.LoginAsync(_email, _password);
        _loading = false;

        if (success) Nav.NavigateTo("/");
        else _error = "Invalid email or password.";
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private void GoToCreate() => Nav.NavigateTo("/create-account");
}
