@using EduConnect.SharedUI.Services
@using EduConnect.SharedUI.Models
@inject IAuthService AuthService
@inject IDataService DataService

<div class="ann-container">
    <div class="ann-list">
        @foreach (var post in _announcements)
        {
            var author = _users.GetValueOrDefault(post.AuthorId);
            <div class="ec-card ann-post">
                <div class="ann-post-header">
                    <div class="ec-avatar">@CssClassHelpers.GetInitials(author?.FullName)</div>
                    <div class="ann-post-meta">
                        <span class="ann-author">@(author?.FullName ?? "Unknown")</span>
                        <span class="ann-time">
                            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                            @FormatTime(post.PostedAt)
                        </span>
                    </div>
                    <button class="ec-icon-btn ann-menu" aria-label="Post options">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                    </button>
                </div>
                <p class="ann-body">@post.Body</p>
                @if (post.Attachments.Any())
                {
                    <div class="ann-attachments">
                        @foreach (var file in post.Attachments)
                        {
                            <div class="ann-file-chip">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <div>
                                    <div style="font-weight:500;">@file.FileName</div>
                                    <div style="font-size:11px;color:var(--color-text-tertiary);">@file.FileType · @file.FileSizeDisplay</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="ec-card ann-composer">
        <h4 style="font-weight:600;margin:0 0 var(--space-3);">Announcements &amp; Discussions</h4>
        <textarea class="ec-input" rows="3" placeholder="Post an update to your classes..." @bind="_newPost"></textarea>
        <div class="ann-composer-toolbar">
            <div class="ann-tools">
                <button class="ec-icon-btn" aria-label="Attachment">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                </button>
                <button class="ec-icon-btn" aria-label="Schedule">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </button>
                <span style="font-size:var(--text-sm);color:var(--color-text-tertiary);">Attachment</span>
                <span style="font-size:var(--text-sm);color:var(--color-text-tertiary);">Schedule</span>
            </div>
            <button class="ec-btn ec-btn-primary" @onclick="PostAnnouncement">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Post Update
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid ClassRoomId { get; set; }

    private List<Announcement> _announcements = new();
    private Dictionary<Guid, AppUser> _users = new();
    private string _newPost = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _announcements = await DataService.GetAnnouncementsAsync(ClassRoomId);
        foreach (var ann in _announcements)
        {
            if (!_users.ContainsKey(ann.AuthorId))
            {
                var user = await DataService.GetUserByIdAsync(ann.AuthorId);
                if (user != null) _users[ann.AuthorId] = user;
            }
        }
    }

    private async Task PostAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(_newPost) || AuthService.CurrentUser == null) return;
        await DataService.PostAnnouncementAsync(new Announcement
        {
            ClassRoomId = ClassRoomId,
            AuthorId = AuthService.CurrentUser.Id,
            Body = _newPost
        });
        _newPost = "";
        await LoadData();
    }

    private string FormatTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hours ago";
        if (diff.TotalDays < 2) return "Yesterday";
        return dt.ToString("MMM d");
    }
}
