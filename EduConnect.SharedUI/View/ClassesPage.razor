@page "/classes"
@using EduConnect.SharedUI.Services
@using EduConnect.SharedUI.Models
@inject IAuthService AuthService
@inject IDataService DataService
@inject NavigationManager Nav

<div class="cls-container page-enter">
    <div class="cls-header">
        <h1 class="cls-title">Classes</h1>
        <select class="ec-input cls-filter" @bind="_selectedYear" @bind:after="LoadClasses" aria-label="Filter by school year">
            @foreach (var year in _schoolYears)
            {
                <option value="@year">@year</option>
            }
        </select>
    </div>

    <div class="cls-grid">
        @foreach (var cls in _filteredClasses)
        {
            var gradients = new[] {
                "linear-gradient(135deg, #6B21A8, #818CF8, #C4B5FD)",
                "linear-gradient(135deg, #2563EB, #06B6D4, #34D399)",
                "linear-gradient(135deg, #10B981, #84CC16, #A3E635)",
                "linear-gradient(135deg, #F59E0B, #F97316, #FBBF24)"
            };
            <div class="cls-card" style="background: @gradients[cls.GradientIndex % 4];"
                 @onclick="() => NavigateToClass(cls.Id)" role="button" tabindex="0"
                 aria-label="Open @cls.Subject class">
                <div class="cls-card-inner">
                    <span class="cls-section-badge">GR@(cls.GradeLevel.Replace("Grade ", ""))-@cls.Section.ToUpper()</span>
                    <h2 class="cls-card-name">@cls.Subject</h2>
                    <p class="cls-card-instructor">Instructor: @GetTeacherName(cls.TeacherId)</p>
                    <div style="margin-top:auto;">
                        <button class="ec-btn ec-btn-sm" style="background:rgba(255,255,255,0.25);color:white;border:1px solid rgba(255,255,255,0.5);border-radius:20px;font-size:12px;" @onclick:stopPropagation="true">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                            Add Students
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<ClassRoom> _classes = new();
    private List<ClassRoom> _filteredClasses = new();
    private List<string> _schoolYears = new() { "2025-2026" };
    private string _selectedYear = "2025-2026";

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.CurrentUser == null) { Nav.NavigateTo("/signin"); return; }
        await LoadClasses();
    }

    private async Task LoadClasses()
    {
        _classes = await DataService.GetClassesAsync(AuthService.CurrentUser!.Id);
        _schoolYears = _classes.Select(c => c.SchoolYear).Distinct().OrderByDescending(y => y).ToList();
        if (!_schoolYears.Contains(_selectedYear) && _schoolYears.Any()) _selectedYear = _schoolYears.First();
        _filteredClasses = _classes.Where(c => c.SchoolYear == _selectedYear).ToList();
    }

    private void NavigateToClass(Guid classId) => Nav.NavigateTo($"/classes/{classId}");

    private string GetTeacherName(Guid teacherId)
    {
        if (AuthService.CurrentUser?.Id == teacherId) return AuthService.CurrentUser.FullName;
        return "Instructor";
    }
}
