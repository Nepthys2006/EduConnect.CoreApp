@namespace EduConnect.SharedUI.Components

<div class="dashboard-content">
    <div class="content-grid">
        <!-- Main Column -->
        <div class="col-main">
            <!-- Welcome Card -->
            <div class="welcome-card">
                <div class="welcome-text">
                    <h2 class="welcome-title">
                        Welcome back,<br/>
                        Gamingh4z3535! <span class="wave">👋</span>
                    </h2>
                    <p class="welcome-description">
                        You have <strong>4 classes</strong> today and <strong>18 new submissions</strong> waiting for your review.
                    </p>
                    <div class="welcome-actions">
                        <button class="btn btn-white">View Schedule</button>
                        <button class="btn btn-outline">Check Gradebook</button>
                    </div>
                </div>
                <div class="welcome-decor">
                    <svg viewBox="0 0 24 24" width="120" height="120" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
            </div>

            <!-- Create Class Card -->
            <div class="create-class-card">
                <h3 class="card-title">+ Create Class</h3>
                <div class="create-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label>SUBJECT</label>
                            <input type="text" class="form-input" placeholder="e.g. Algebra I" />
                        </div>
                        <div class="form-group form-group-sm">
                            <label>GRADE</label>
                            <select class="form-input">
                                <option>7</option>
                                <option>8</option>
                                <option>9</option>
                                <option>10</option>
                                <option>11</option>
                                <option>12</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>SECTION</label>
                            <input type="text" class="form-input" placeholder="e.g. Plato" />
                        </div>
                        <div class="form-group form-group-sm">
                            <label>S.Y.</label>
                            <select class="form-input">
                                <option>2025-2026</option>
                                <option>2024-2025</option>
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-create">Create</button>
                </div>
            </div>

            <!-- Upcoming Classes -->
            <div class="upcoming-card">
                <h3 class="upcoming-title">Upcoming Classes Today</h3>
                <div class="class-list">
                    <div class="class-item">
                        <div class="class-accent"></div>
                        <div class="class-details">
                            <span class="class-tag">Grade 9</span>
                            <h4 class="class-name">Intro to Particle Physics</h4>
                            <div class="class-meta">
                                <span class="meta-item">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"/>
                                        <polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    04:00 PM – 05:30 PM
                                </span>
                                <span class="meta-item">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                        <circle cx="9" cy="7" r="4"/>
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                    Plato
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Side Column -->
        <div class="col-side">
            <div class="todo-card">
                <h3 class="todo-title">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20h9"/>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                    </svg>
                    To-Do / Grading
                </h3>
                <div class="todo-list">
                    <div class="todo-item">
                        <div class="todo-content">
                            <h4 class="todo-name">Grade Calculus HW #4</h4>
                            <p class="todo-desc">24/30 students submitted</p>
                        </div>
                        <span class="badge badge-today">Today</span>
                    </div>
                    <div class="todo-item">
                        <div class="todo-content">
                            <h4 class="todo-name">Review Lab Reports</h4>
                            <p class="todo-desc">12/28 students submitted</p>
                        </div>
                        <span class="badge badge-tomorrow">Tomorrow</span>
                    </div>
                    <div class="todo-item">
                        <div class="todo-content">
                            <h4 class="todo-name">Review Lab Reports</h4>
                            <p class="todo-desc">8/22 students submitted</p>
                        </div>
                        <span class="badge badge-tomorrow">Tomorrow</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
