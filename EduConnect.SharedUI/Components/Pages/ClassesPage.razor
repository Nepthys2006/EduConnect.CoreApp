@page "/classes"
@inject IDataService DataService
@inject NavigationManager Navigation

<PageTitle>Classes - EduConnect</PageTitle>

<div class="cls-container">
    <div class="cls-header">
        <h1 class="cls-title">My Classes</h1>
        <select class="ec-input cls-filter" @bind="SelectedYear">
            <option>2025-2026</option>
            <option>2024-2025</option>
        </select>
    </div>

    <div class="cls-grid">
        @foreach (var c in Classes)
        {
            <div class="cls-card @CssClassHelpers.GetGradientClass(c.ClassId)" @onclick="() => GoToClass(c.ClassId)">
                <div class="cls-card-inner">
                    <span class="cls-section-badge">@c.Section</span>
                    <h3 class="cls-card-name">@c.Subject</h3>
                    <p class="cls-card-instructor">@c.Instructor?.Name</p>
                    <button class="ec-btn ec-btn-sm" style="background:rgba(255,255,255,0.18); color:white; border-color:rgba(255,255,255,0.30); margin-top:auto;" @onclick:stopPropagation>
                        Add Students
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<Class> Classes { get; set; } = new();
    private string SelectedYear { get; set; } = "2025-2026";

    protected override async Task OnInitializedAsync()
    {
        Classes = await DataService.GetTeacherClassesAsync("teacher-001");
    }

    private void GoToClass(string classId) => Navigation.NavigateTo($"/class/{classId}");
}
