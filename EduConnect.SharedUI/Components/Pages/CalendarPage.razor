@page "/calendar"
@inject IDataService DataService

<PageTitle>Calendar - EduConnect</PageTitle>

<div class="cal-container">
    <div class="cal-header">
        <h1 class="cal-title">Calendar</h1>
        <button class="ec-btn ec-btn-primary" @onclick="() => ShowAddAssignment = true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Assignment
        </button>
    </div>

    <div class="cal-grid">
        <div class="cal-main">
            <div class="ec-card">
                <div class="cal-toolbar">
                    <button class="ec-icon-btn" @onclick="PrevMonth">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <h2 class="cal-month">@CurrentMonth.ToString("MMMM yyyy")</h2>
                    <button class="ec-icon-btn" @onclick="NextMonth">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>

                <div class="cal-weekdays">
                    @foreach (var d in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                    {
                        <div class="cal-weekday">@d</div>
                    }
                </div>
                <div class="cal-days">
                    @foreach (var day in CalendarDays)
                    {
                        <div class="cal-day @(day.IsCurrentMonth ? "" : "cal-day-muted") @(day.IsToday ? "cal-day-today" : "")">
                            <span class="cal-day-num">@day.Day</span>
                            @if (day.Events.Any())
                            {
                                <div class="cal-day-events">
                                    @foreach (var evt in day.Events.Take(2))
                                    {
                                        <span class="cal-event-chip @GetEventColor(evt)">@evt.Title</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="cal-side">
            <div class="ec-card cal-panel">
                <h3 class="cal-panel-title">Upcoming Grading</h3>
                <div class="cal-deadline-list">
                    @foreach (var a in UpcomingAssignments)
                    {
                        <div class="cal-deadline">
                            <div class="cal-deadline-info">
                                <span class="cal-deadline-name">@a.AssignmentTitle</span>
                                <span class="cal-deadline-date">@a.DueDate.ToString("MMM dd")</span>
                            </div>
                            <span class="ec-badge @CssClassHelpers.GetDueBadgeClass(a.DueDate)">@CssClassHelpers.GetDueBadgeText(a.DueDate)</span>
                        </div>
                    }
                </div>
            </div>
            <div class="ec-card cal-panel" style="margin-top: var(--space-5);">
                <h3 class="cal-panel-title">Recent Submissions</h3>
                <div class="cal-submission-list">
                    @foreach (var sub in RecentSubmissions)
                    {
                        <div class="cal-submission">
                            <div class="ec-avatar">@CssClassHelpers.GetInitials(sub.Student?.Name)</div>
                            <div class="cal-submission-info">
                                <span class="cal-submission-name">@sub.Student?.Name</span>
                                <span class="cal-submission-meta">@sub.Assignment?.AssignmentTitle · @sub.SubmittedAt?.ToString("MMM dd, h:mm tt")</span>
                            </div>
                            <span class="ec-badge ec-badge-primary">New</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (ShowAddAssignment)
{
    <div class="ec-modal-backdrop" @onclick="() => ShowAddAssignment = false">
        <div class="ec-modal" @onclick:stopPropagation>
            <div class="ec-modal-header">
                <h3>Add Assignment</h3>
                <button class="ec-icon-btn" @onclick="() => ShowAddAssignment = false">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="ec-modal-body">
                <div style="display:flex;flex-direction:column;gap:var(--space-4);">
                    <div>
                        <label class="td-label">Title</label>
                        <input class="ec-input" type="text" placeholder="Assignment title" />
                    </div>
                    <div>
                        <label class="td-label">Description</label>
                        <textarea class="ec-input" placeholder="Description"></textarea>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);">
                        <div>
                            <label class="td-label">Due Date</label>
                            <input class="ec-input" type="date" />
                        </div>
                        <div>
                            <label class="td-label">Points</label>
                            <input class="ec-input" type="number" placeholder="100" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="ec-modal-footer">
                <button class="ec-btn ec-btn-secondary" @onclick="() => ShowAddAssignment = false">Cancel</button>
                <button class="ec-btn ec-btn-primary">Create</button>
            </div>
        </div>
    </div>
}

@code {
    private DateTime CurrentMonth { get; set; } = DateTime.UtcNow;
    private List<CalendarDay> CalendarDays { get; set; } = new();
    private List<Assignment> UpcomingAssignments { get; set; } = new();
    private List<Submission> RecentSubmissions { get; set; } = new();
    private bool ShowAddAssignment { get; set; } = false;
    private List<CalendarEvent> Events { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendar();
        var classes = await DataService.GetTeacherClassesAsync("teacher-001");
        foreach (var c in classes)
        {
            var assignments = await DataService.GetClassAssignmentsAsync(c.ClassId);
            UpcomingAssignments.AddRange(assignments.Where(a => a.DueDate >= DateTime.UtcNow.Date));
        }
        UpcomingAssignments = UpcomingAssignments.OrderBy(a => a.DueDate).Take(4).ToList();
        RecentSubmissions = await DataService.GetRecentSubmissionsAsync("teacher-001", 4);
        Events = await DataService.GetCalendarEventsAsync("teacher-001", CurrentMonth);
    }

    private async Task LoadCalendar()
    {
        CalendarDays = new List<CalendarDay>();
        var firstOfMonth = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var startDay = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);

        for (int i = 0; i < 42; i++)
        {
            var date = startDay.AddDays(i);
            var dayEvents = Events.Where(e => e.StartDate.Date == date.Date).ToList();
            CalendarDays.Add(new CalendarDay
            {
                Day = date.Day,
                Date = date,
                IsCurrentMonth = date.Month == CurrentMonth.Month,
                IsToday = date.Date == DateTime.UtcNow.Date,
                Events = dayEvents
            });
        }
    }

    private async Task PrevMonth() { CurrentMonth = CurrentMonth.AddMonths(-1); Events = await DataService.GetCalendarEventsAsync("teacher-001", CurrentMonth); await LoadCalendar(); }
    private async Task NextMonth() { CurrentMonth = CurrentMonth.AddMonths(1); Events = await DataService.GetCalendarEventsAsync("teacher-001", CurrentMonth); await LoadCalendar(); }

    private string GetEventColor(CalendarEvent evt)
    {
        var preset = int.TryParse(evt.ClassColorPreset, out var p) ? p : 1;
        return $"ec-gradient-{preset}";
    }

    private class CalendarDay
    {
        public int Day { get; set; }
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsToday { get; set; }
        public List<CalendarEvent> Events { get; set; } = new();
    }
}
