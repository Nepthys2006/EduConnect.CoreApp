@inject IDataService DataService
@inject NavigationManager Navigation

<PageTitle>Dashboard - EduConnect</PageTitle>

<div class="td-container">
    <!-- Welcome Banner -->
    <div class="td-welcome">
        <div class="td-welcome-text">
            <h1 class="td-welcome-title">Welcome back, @UserName! <span class="td-wave">👋</span></h1>
            <p class="td-welcome-sub">You have <strong>@UpcomingClasses.Count classes</strong> today and <strong>@PendingSubmissionsCount new submissions</strong> waiting for your review.</p>
            <div class="td-welcome-actions">
                <button class="ec-btn ec-btn-secondary" style="background:rgba(255,255,255,0.12); color:white; border-color:rgba(255,255,255,0.25);">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    View Schedule
                </button>
                <button class="ec-btn ec-btn-secondary" style="background:rgba(255,255,255,0.12); color:white; border-color:rgba(255,255,255,0.25);">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Check Gradebook
                </button>
            </div>
        </div>
        <div class="td-welcome-illust">
            <svg viewBox="0 0 24 24" width="120" height="120" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M12 6v7"/><path d="M9 9h6"/>
            </svg>
        </div>
    </div>

    <div class="td-grid">
        <!-- Create Class -->
        <div class="td-col-main">
            <div class="ec-card">
                <h3 class="td-card-title">+ Create Class</h3>
                <div class="td-create-form">
                    <div class="td-form-row">
                        <div class="td-form-group">
                            <label class="td-label">SUBJECT</label>
                            <input class="ec-input" type="text" @bind="NewSubject" placeholder="e.g. Algebra I" />
                        </div>
                        <div class="td-form-group td-form-sm">
                            <label class="td-label">GRADE</label>
                            <select class="ec-input" @bind="NewGrade">
                                <option>7</option><option>8</option><option>9</option><option>10</option><option>11</option><option>12</option>
                            </select>
                        </div>
                        <div class="td-form-group">
                            <label class="td-label">SECTION</label>
                            <input class="ec-input" type="text" @bind="NewSection" placeholder="e.g. Plato" />
                        </div>
                        <div class="td-form-group td-form-sm">
                            <label class="td-label">S.Y.</label>
                            <select class="ec-input" @bind="NewSchoolYear">
                                <option>2025-2026</option><option>2024-2025</option>
                            </select>
                        </div>
                    </div>
                    <button class="ec-btn ec-btn-primary" @onclick="CreateClass">Create</button>
                </div>
            </div>

            <!-- Upcoming Classes -->
            <div class="ec-card" style="margin-top: var(--space-6);">
                <h3 class="td-card-title">Upcoming Classes Today</h3>
                @if (UpcomingClasses.Count == 0)
                {
                    <div class="td-empty">No upcoming classes for today.</div>
                }
                else
                {
                    <div class="td-class-list">
                        @foreach (var item in UpcomingClasses)
                        {
                            <div class="td-class-row" @onclick="() => GoToClass(item.ClassId)">
                                <div class="td-class-accent @CssClassHelpers.GetGradientClass(item.ClassId)"></div>
                                <div class="td-class-body">
                                    <span class="ec-badge ec-badge-primary">Grade @item.Grade</span>
                                    <h4 class="td-class-name">@item.Subject</h4>
                                    <div class="td-class-meta">
                                        <span class="td-meta-item">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            08:00 AM – 09:30 AM
                                        </span>
                                        <span class="td-meta-item">
                                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                            @item.Section
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- To-Do / Grading -->
        <div class="td-col-side">
            <div class="ec-card">
                <h3 class="td-card-title">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    To-Do / Grading
                </h3>
                <div class="td-todo-list">
                    @foreach (var a in TodoAssignments)
                    {
                        <div class="td-todo-item" @onclick="() => GoToClass(a.ClassId)">
                            <div class="td-todo-content">
                                <h4 class="td-todo-name">@a.AssignmentTitle</h4>
                                <p class="td-todo-desc">@GetSubmissionCount(a.AssignmentId) students submitted</p>
                            </div>
                            <span class="ec-badge @CssClassHelpers.GetDueBadgeClass(a.DueDate)">@CssClassHelpers.GetDueBadgeText(a.DueDate)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string UserName { get; set; } = "Teacher";
    private string NewSubject { get; set; } = "";
    private string NewGrade { get; set; } = "9";
    private string NewSection { get; set; } = "";
    private string NewSchoolYear { get; set; } = "2025-2026";
    private List<Class> UpcomingClasses { get; set; } = new();
    private List<Assignment> TodoAssignments { get; set; } = new();
    private int PendingSubmissionsCount { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        var user = await DataService.GetCurrentUserAsync();
        if (user != null) UserName = user.Name;

        var classes = await DataService.GetTeacherClassesAsync("teacher-001");
        UpcomingClasses = classes.Take(3).ToList();

        foreach (var c in classes)
        {
            var assignments = await DataService.GetClassAssignmentsAsync(c.ClassId);
            TodoAssignments.AddRange(assignments.Where(a => a.DueDate >= DateTime.UtcNow.Date.AddDays(-1)));
        }
        TodoAssignments = TodoAssignments.OrderBy(a => a.DueDate).Take(4).ToList();

        var recentSubs = await DataService.GetRecentSubmissionsAsync("teacher-001", 20);
        PendingSubmissionsCount = recentSubs.Count(s => s.Score == null);
    }

    private async Task CreateClass()
    {
        if (string.IsNullOrWhiteSpace(NewSubject) || string.IsNullOrWhiteSpace(NewSection)) return;
        var newClass = new Class
        {
            Subject = NewSubject,
            Grade = NewGrade,
            Section = NewSection,
            SchoolYear = NewSchoolYear
        };
        await DataService.CreateClassAsync(newClass);
        var classes = await DataService.GetTeacherClassesAsync("teacher-001");
        UpcomingClasses = classes.Take(3).ToList();
        NewSubject = ""; NewSection = "";
        StateHasChanged();
    }

    private void GoToClass(string classId) => Navigation.NavigateTo($"/class/{classId}");

    private int GetSubmissionCount(string assignmentId)
    {
        // Simplified - in a real scenario this would query submissions
        return 12; // Placeholder
    }
}
