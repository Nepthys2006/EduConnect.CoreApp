@inject IDataService DataService
@implements IDisposable

<div class="att-container">
    <div class="att-calendar">
        <div class="att-cal-header">
            <button class="ec-icon-btn" @onclick="PrevMonth">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <h3 class="att-cal-title">@CurrentMonth.ToString("MMMM yyyy")</h3>
            <button class="ec-icon-btn" @onclick="NextMonth">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
        </div>
        <div class="att-cal-grid">
            @foreach (var d in new[] { "S","M","T","W","T","F","S" })
            {
                <div class="att-cal-weekday">@d</div>
            }
            @foreach (var day in CalendarDays)
            {
                <div class="att-cal-day @(day.IsCurrentMonth ? "" : "att-cal-muted") @(day.IsSelected ? "att-cal-selected" : "") @(day.IsToday ? "att-cal-today" : "")" @onclick="() => SelectDate(day.Date)">
                    <span class="att-cal-daynum">@day.Day</span>
                    @if (day.HasRecords)
                    {
                        <span class="att-cal-dot"></span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="att-roster">
        <div class="att-roster-header">
            <div class="att-date-selector">
                <label class="td-label">Date</label>
                <input class="ec-input" type="date" @bind="SelectedDate" />
            </div>
            <button class="ec-btn ec-btn-secondary" @onclick="MarkAllPresent">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                Mark All Present
            </button>
        </div>

        <table class="ec-table att-table">
            <thead>
                <tr><th>Student</th><th style="font-family:'JetBrains Mono',monospace;">LRN#</th><th>Status</th><th>Toggle</th></tr>
            </thead>
            <tbody>
                @foreach (var student in Students)
                {
                    var record = Attendance.FirstOrDefault(a => a.StudentId == student.UserId);
                    var status = record?.Status ?? "Not Set";
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:var(--space-2);">
                                <div class="ec-avatar">@CssClassHelpers.GetInitials(student.User?.Name)</div>
                                <span>@student.User?.Name</span>
                            </div>
                        </td>
                        <td style="font-family:'JetBrains Mono',monospace;font-size:var(--text-sm);color:var(--color-text-secondary);">@student.User?.LearnerReferenceNumber</td>
                        <td><span class="ec-badge @CssClassHelpers.GetStatusBadgeClass(status)">@status</span></td>
                        <td>
                            <div class="att-toggle">
                                <button class="ec-btn ec-btn-sm @(status == "Present" ? "ec-btn-primary" : "ec-btn-secondary")" @onclick="() => MarkPresent(student.UserId)">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                </button>
                                <button class="ec-btn ec-btn-sm @(status == "Absent" ? "ec-btn-danger" : "ec-btn-secondary")" @onclick="() => MarkAbsent(student.UserId)">
                                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ShowToast)
    {
        <div class="ec-toast-container">
            <div class="ec-toast">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--color-success)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Attendance saved</span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private DateTime CurrentMonth { get; set; } = DateTime.UtcNow;
    private DateTime SelectedDate { get; set; } = DateTime.UtcNow.Date;
    private List<Member> Students { get; set; } = new();
    private List<AttendanceRecord> Attendance { get; set; } = new();
    private List<CalendarDay> CalendarDays { get; set; } = new();
    private bool ShowToast { get; set; } = false;
    private System.Timers.Timer? _toastTimer;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
        {
            var members = await DataService.GetClassMembersAsync(ClassId);
            Students = members.Where(m => m.Role == "Student").ToList();
            await LoadAttendance();
            BuildCalendar();
        }
    }

    private async Task LoadAttendance()
    {
        Attendance = await DataService.GetAttendanceForDateAsync(ClassId, SelectedDate);
        StateHasChanged();
    }

    private async Task SetStatus(string studentId, string status)
    {
        await DataService.SaveAttendanceAsync(new AttendanceRecord
        {
            ClassId = ClassId,
            StudentId = studentId,
            Date = SelectedDate,
            Status = status
        });
        await LoadAttendance();
        ShowToastNotification();
    }

    private async Task MarkAllPresent()
    {
        await DataService.MarkAllPresentAsync(ClassId, SelectedDate);
        await LoadAttendance();
        ShowToastNotification();
    }

    private async Task MarkPresent(string studentId) => await SetStatus(studentId, "Present");
    private async Task MarkAbsent(string studentId) => await SetStatus(studentId, "Absent");

    private void ShowToastNotification()
    {
        ShowToast = true;
        _toastTimer?.Dispose();
        _toastTimer = new System.Timers.Timer(3000);
        _toastTimer.Elapsed += (s, e) => { ShowToast = false; InvokeAsync(StateHasChanged); };
        _toastTimer.AutoReset = false;
        _toastTimer.Start();
    }

    private void BuildCalendar()
    {
        CalendarDays = new List<CalendarDay>();
        var first = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var start = first.AddDays(-(int)first.DayOfWeek);
        for (int i = 0; i < 42; i++)
        {
            var dt = start.AddDays(i);
            CalendarDays.Add(new CalendarDay
            {
                Day = dt.Day,
                Date = dt,
                IsCurrentMonth = dt.Month == CurrentMonth.Month,
                IsToday = dt.Date == DateTime.UtcNow.Date,
                IsSelected = dt.Date == SelectedDate.Date,
                HasRecords = Attendance.Any(a => a.Date.Date == dt.Date)
            });
        }
    }

    private async Task SelectDate(DateTime date) { SelectedDate = date; await LoadAttendance(); }
    private void PrevMonth() { CurrentMonth = CurrentMonth.AddMonths(-1); BuildCalendar(); }
    private void NextMonth() { CurrentMonth = CurrentMonth.AddMonths(1); BuildCalendar(); }

    public void Dispose() => _toastTimer?.Dispose();

    private class CalendarDay
    {
        public int Day { get; set; }
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsToday { get; set; }
        public bool IsSelected { get; set; }
        public bool HasRecords { get; set; }
    }
}
