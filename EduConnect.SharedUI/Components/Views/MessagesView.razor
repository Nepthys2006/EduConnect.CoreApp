@inject IDataService DataService

<div class="msg-container">
    <div class="msg-sidebar">
        <button class="ec-btn ec-btn-primary" style="width:100%;margin-bottom:var(--space-4);">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Message
        </button>
        <div class="msg-search">
            <input class="ec-input" type="text" placeholder="Search conversations..." />
        </div>
        <div class="msg-conv-list">
            @foreach (var conv in Conversations)
            {
                <div class="msg-conv @(SelectedConversation?.ConversationId == conv.ConversationId ? "active" : "")" @onclick="() => SelectConversation(conv)">
                    <div class="ec-avatar">@CssClassHelpers.GetInitials(conv.OtherParticipant?.Name)</div>
                    <div class="msg-conv-info">
                        <div class="msg-conv-top">
                            <span class="msg-conv-name">@conv.Title</span>
                            <span class="msg-conv-time">@conv.LastMessage?.SentAt.ToString("h:mm tt")</span>
                        </div>
                        <div class="msg-conv-preview">@conv.LastMessage?.Content</div>
                    </div>
                    @if (conv.UnreadCount > 0)
                    {
                        <span class="msg-unread">@conv.UnreadCount</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="msg-view">
        @if (SelectedConversation == null)
        {
            <div class="msg-empty">Select a conversation to start messaging</div>
        }
        else
        {
            <div class="msg-view-header">
                <div class="ec-avatar ec-avatar-lg">@CssClassHelpers.GetInitials(SelectedConversation.OtherParticipant?.Name)</div>
                <div>
                    <h4 style="margin:0;">@SelectedConversation.Title</h4>
                    <span style="font-size:var(--text-sm);color:var(--color-text-tertiary);">@SelectedConversation.OtherParticipant?.Email</span>
                </div>
            </div>
            <div class="msg-messages" id="msg-scroll">
                @foreach (var msg in Messages)
                {
                    <div class="msg-bubble @GetBubbleClass(msg.SenderId)">
                        <div class="msg-bubble-content">@msg.Content</div>
                        <span class="msg-bubble-time">@msg.SentAt.ToString("h:mm tt")</span>
                    </div>
                }
            </div>
            <div class="msg-composer">
                <div class="msg-composer-toolbar">
                    <button class="ec-icon-btn" title="Bold"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg></button>
                    <button class="ec-icon-btn" title="Italic"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
                    <button class="ec-icon-btn" title="Link"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>
                    <button class="ec-icon-btn" title="Attach"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg></button>
                </div>
                <div style="display:flex;gap:var(--space-2);align-items:flex-end;">
                    <textarea class="ec-input" @bind="NewMessage" rows="1" style="resize:none;min-height:40px;" placeholder="Type a message..."></textarea>
                    <button class="ec-btn ec-btn-primary ec-btn-icon" style="height:38px;width:38px;flex-shrink:0;" @onclick="SendMessage">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Conversation> Conversations { get; set; } = new();
    private Conversation? SelectedConversation { get; set; }
    private List<Message> Messages { get; set; } = new();
    private string NewMessage { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        Conversations = await DataService.GetConversationsAsync("teacher-001");
    }

    private async Task SelectConversation(Conversation conv)
    {
        SelectedConversation = conv;
        Messages = await DataService.GetMessagesAsync(conv.ConversationId);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(NewMessage) || SelectedConversation == null) return;
        await DataService.SendMessageAsync(SelectedConversation.ConversationId, "teacher-001", NewMessage);
        Messages = await DataService.GetMessagesAsync(SelectedConversation.ConversationId);
        NewMessage = "";
    }

    private string GetBubbleClass(string senderId) => senderId == "teacher-001" ? "msg-bubble-me" : "msg-bubble-them";
}
