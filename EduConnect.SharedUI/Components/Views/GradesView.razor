@inject IDataService DataService

<div class="grd-container">
    <div class="grd-header">
        <h3 class="grd-title">Gradebook</h3>
        <button class="ec-btn ec-btn-primary" @onclick="() => ShowTermSummary = true">End of Term Summary</button>
    </div>

    <table class="ec-table grd-table">
        <thead>
            <tr><th>Item</th><th>Due Date</th><th>Status</th><th>Score</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var a in Assignments)
            {
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:var(--space-2);">
                            <span class="grd-type-icon @GetTypeColor(a.AssignmentType)">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">@((MarkupString)GetTypeIcon(a.AssignmentType))</svg>
                            </span>
                            <span>@a.AssignmentTitle</span>
                        </div>
                    </td>
                    <td>@a.DueDate.ToString("MMM dd, yyyy")</td>
                    <td><span class="ec-badge @GetStatusBadge(a.AssignmentStatus)">@a.AssignmentStatus</span></td>
                    <td>
                        @if (EditingScore == a.AssignmentId)
                        {
                            <input class="ec-input" style="width:80px;height:32px;" type="number" @bind="EditScoreValue" @onblur="() => SaveScore(a.AssignmentId)" @onkeydown="e => HandleScoreKey(e, a.AssignmentId)" />
                        }
                        else
                        {
                            <span class="grd-score" @onclick="() => StartEditScore(a.AssignmentId)">@GetAverageScore(a.AssignmentId) / @a.TotalPoints</span>
                        }
                    </td>
                    <td><button class="ec-icon-btn" @onclick="() => StartEditScore(a.AssignmentId)"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4L18.5 2.5z"/></svg></button></td>
                </tr>
            }
        </tbody>
    </table>

    <div class="grd-summary">
        <span>@Assignments.Count total assignments</span>
        <span>·</span>
        <span>@Assignments.Count(a => a.AssignmentStatus == "Ongoing") active</span>
    </div>
</div>

<!-- Term Summary Modal -->
@if (ShowTermSummary)
{
    <div class="ec-modal-backdrop" @onclick="() => ShowTermSummary = false">
        <div class="ec-modal" style="max-width:700px;" @onclick:stopPropagation>
            <div class="ec-modal-header">
                <h3>End of Term Summary</h3>
                <button class="ec-icon-btn" @onclick="() => ShowTermSummary = false"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
            </div>
            <div class="ec-modal-body">
                <table class="ec-table">
                    <thead>
                        <tr><th>Student</th><th>Points Earned</th><th>Points Possible</th><th>Percentage</th><th>Grade</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Students)
                        {
                            <tr>
                                <td>@s.Name</td>
                                <td>@GetRandomEarned()</td>
                                <td>@TotalPossible</td>
                                <td>@GetRandomPercent()%</td>
                                <td><span class="ec-badge ec-badge-primary">@GetLetterGrade()</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="ec-modal-footer">
                <button class="ec-btn ec-btn-secondary" @onclick="() => ShowTermSummary = false">Close</button>
                <button class="ec-btn ec-btn-primary">Export CSV</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Assignment> Assignments { get; set; } = new();
    private bool ShowTermSummary { get; set; } = false;
    private string? EditingScore { get; set; }
    private double? EditScoreValue { get; set; }
    private List<User> Students { get; set; } = new();
    private double TotalPossible => Assignments.Sum(a => a.TotalPoints);
    private Random _rnd = new Random();

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
        {
            Assignments = await DataService.GetClassAssignmentsAsync(ClassId);
            var members = await DataService.GetClassMembersAsync(ClassId);
            Students = members.Where(m => m.Role == "Student" && m.User != null).Select(m => m.User!).ToList();
        }
    }

    private string GetAverageScore(string assignmentId) => "—";
    private void StartEditScore(string assignmentId) { EditingScore = assignmentId; EditScoreValue = null; }
    private void SaveScore(string assignmentId) { EditingScore = null; }
    private void HandleScoreKey(KeyboardEventArgs e, string assignmentId) { if (e.Key == "Enter") SaveScore(assignmentId); }

    private string GetTypeColor(string type) => type.ToLower() switch { "code" => "asn-type-blue", "quiz" => "asn-type-orange", "essay" => "asn-type-purple", _ => "asn-type-teal" };
    private string GetTypeIcon(string type) => type.ToLower() switch { "code" => "<polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/>", "quiz" => "<path d=\"M9 11l3 3L22 4\"/><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"/>", _ => "<path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z\"/>" };
    private string GetStatusBadge(string status) => status.ToLower() switch { "ongoing" => "ec-badge-primary", "pending" => "ec-badge-warning", _ => "ec-badge-neutral" };
    private int GetRandomEarned() => _rnd.Next(60, 100);
    private int GetRandomPercent() => _rnd.Next(75, 98);
    private string GetLetterGrade() => new[] { "A", "B+", "B", "C+", "C" }[_rnd.Next(5)];
}
