@inject IDataService DataService

<div class="mem-container">
    <div class="mem-header">
        <div class="mem-header-left">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--color-text-secondary)" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="mem-count">@Members.Count members</span>
        </div>
        <button class="ec-btn ec-btn-primary" @onclick="() => ShowJoinRequests = true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Student Requests
        </button>
    </div>

    <table class="ec-table mem-table">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Role</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var m in Members)
            {
                <tr>
                    <td>
                        <div class="mem-name">
                            <div class="ec-avatar">@CssClassHelpers.GetInitials(m.User?.Name)</div>
                            <span>@m.User?.Name</span>
                            @if (m.Role == "Teacher")
                            {
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="var(--color-primary)" stroke-width="2" title="Verified"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            }
                        </div>
                    </td>
                    <td class="mem-email">@m.User?.Email</td>
                    <td><span class="ec-badge @CssClassHelpers.GetRoleBadgeClass(m.Role)">@m.Role</span></td>
                    <td>
                        @if (m.Role == "Student")
                        {
                            <button class="ec-icon-btn" title="Remove" @onclick="() => RemoveMember(m.MemberId)">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Join Requests Modal -->
@if (ShowJoinRequests)
{
    <div class="ec-modal-backdrop" @onclick="() => ShowJoinRequests = false">
        <div class="ec-modal" @onclick:stopPropagation>
            <div class="ec-modal-header">
                <h3>Student Join Requests</h3>
                <button class="ec-icon-btn" @onclick="() => ShowJoinRequests = false">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="ec-modal-body">
                @if (JoinRequests.Count == 0)
                {
                    <div class="act-empty"><p>No pending requests.</p></div>
                }
                else
                {
                    <div class="mem-request-list">
                        @foreach (var jr in JoinRequests)
                        {
                            <div class="mem-request-row">
                                <div class="mem-request-info">
                                    <div class="ec-avatar">@CssClassHelpers.GetInitials(jr.Student?.Name)</div>
                                    <div>
                                        <span class="mem-request-name">@jr.Student?.Name</span>
                                        <span class="mem-request-lrn" style="font-family:'JetBrains Mono',monospace;font-size:var(--text-xs);color:var(--color-text-tertiary);display:block;">LRN: @jr.Student?.LearnerReferenceNumber</span>
                                    </div>
                                </div>
                                <div class="mem-request-actions">
                                    @if (ResolvedRequests.Contains(jr.RequestId))
                                    {
                                        <span class="ec-badge ec-badge-success">Accepted</span>
                                    }
                                    else
                                    {
                                        <button class="ec-btn ec-btn-sm ec-btn-secondary" style="color:var(--color-success);border-color:var(--color-success);" @onclick="() => AcceptRequest(jr.RequestId)">Accept</button>
                                        <button class="ec-btn ec-btn-sm ec-btn-secondary" style="color:var(--color-danger);border-color:var(--color-danger);" @onclick="() => RejectRequest(jr.RequestId)">Reject</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="ec-modal-footer">
                <button class="ec-btn ec-btn-secondary" @onclick="() => ShowJoinRequests = false">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Member> Members { get; set; } = new();
    private bool ShowJoinRequests { get; set; } = false;
    private List<JoinRequest> JoinRequests { get; set; } = new();
    private HashSet<string> ResolvedRequests { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
        {
            Members = await DataService.GetClassMembersAsync(ClassId);
            JoinRequests = await DataService.GetPendingJoinRequestsAsync(ClassId);
        }
    }

    private async Task RemoveMember(string memberId)
    {
        await DataService.RemoveMemberAsync(memberId);
        Members = await DataService.GetClassMembersAsync(ClassId);
    }

    private async Task AcceptRequest(string requestId)
    {
        await DataService.AcceptJoinRequestAsync(requestId);
        ResolvedRequests.Add(requestId);
        Members = await DataService.GetClassMembersAsync(ClassId);
    }

    private async Task RejectRequest(string requestId)
    {
        await DataService.RejectJoinRequestAsync(requestId);
        ResolvedRequests.Add(requestId);
        JoinRequests = await DataService.GetPendingJoinRequestsAsync(ClassId);
    }
}
