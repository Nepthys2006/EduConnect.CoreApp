@inject IDataService DataService

<div class="cnt-container">
    <div class="cnt-grid">
        <div class="ec-card cnt-add" @onclick="() => ShowAddFolder = true">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="var(--color-border-strong)" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <span class="cnt-add-label">Add New Folder</span>
            <span class="cnt-add-hint">Create a module folder</span>
        </div>

        @foreach (var folder in Folders)
        {
            <div class="ec-card cnt-folder">
                <div class="cnt-folder-header" @onclick="() => ToggleFolder(folder.FolderId)">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    <div class="cnt-folder-info">
                        <h4 class="cnt-folder-name">@folder.FolderName</h4>
                        <p class="cnt-folder-desc">@folder.Description</p>
                    </div>
                    <div class="cnt-folder-actions">
                        <span class="cnt-folder-count">@folder.ItemIds.Count items</span>
                        <svg class="cnt-chevron @(ExpandedFolders.Contains(folder.FolderId) ? "open" : "")" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                </div>
                @if (ExpandedFolders.Contains(folder.FolderId))
                {
                    <div class="cnt-folder-items">
                        @foreach (var item in folder.ItemIds)
                        {
                            <div class="cnt-item">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--color-text-tertiary)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span class="cnt-item-name">@item</span>
                                <div class="cnt-item-actions">
                                    <button class="ec-icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
                                    <button class="ec-icon-btn"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (ShowAddFolder)
{
    <div class="ec-modal-backdrop" @onclick="() => ShowAddFolder = false">
        <div class="ec-modal" @onclick:stopPropagation>
            <div class="ec-modal-header">
                <h3>Add New Folder</h3>
                <button class="ec-icon-btn" @onclick="() => ShowAddFolder = false">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="ec-modal-body">
                <div style="display:flex;flex-direction:column;gap:var(--space-4);">
                    <div>
                        <label class="td-label">Folder Name</label>
                        <input class="ec-input" @bind="NewFolderName" placeholder="e.g. Module 3" />
                    </div>
                    <div>
                        <label class="td-label">Description</label>
                        <textarea class="ec-input" @bind="NewFolderDesc" rows="2" placeholder="Short description"></textarea>
                    </div>
                </div>
            </div>
            <div class="ec-modal-footer">
                <button class="ec-btn ec-btn-secondary" @onclick="() => ShowAddFolder = false">Cancel</button>
                <button class="ec-btn ec-btn-primary" @onclick="AddFolder">Create</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Folder> Folders { get; set; } = new();
    private HashSet<string> ExpandedFolders { get; set; } = new();
    private bool ShowAddFolder { get; set; } = false;
    private string NewFolderName { get; set; } = "";
    private string NewFolderDesc { get; set; } = "";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
            Folders = await DataService.GetClassFoldersAsync(ClassId);
    }

    private void ToggleFolder(string folderId)
    {
        if (ExpandedFolders.Contains(folderId)) ExpandedFolders.Remove(folderId);
        else ExpandedFolders.Add(folderId);
    }

    private void AddFolder()
    {
        ShowAddFolder = false;
        NewFolderName = "";
        NewFolderDesc = "";
    }
}
