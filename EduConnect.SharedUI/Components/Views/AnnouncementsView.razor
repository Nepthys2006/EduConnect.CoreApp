@inject IDataService DataService

<div class="ann-container">
    <div class="ann-list">
        @foreach (var post in Announcements)
        {
            <div class="ec-card ann-post">
                <div class="ann-post-header">
                    <div class="ec-avatar">@CssClassHelpers.GetInitials(post.Author?.Name)</div>
                    <div class="ann-post-meta">
                        <span class="ann-author">@post.Author?.Name</span>
                        <span class="ann-time">@post.AnnouncementDate.ToString("MMM dd, h:mm tt")</span>
                    </div>
                    <div class="ann-menu">
                        <button class="ec-icon-btn">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                        </button>
                    </div>
                </div>
                <p class="ann-body">@post.AnnouncementDescription</p>
                @if (!string.IsNullOrEmpty(post.Attachments))
                {
                    <div class="ann-attachments">
                        <div class="ann-file-chip">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                            <span>@post.Attachments</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="ec-card ann-composer">
        <textarea class="ec-input" @bind="NewPostContent" rows="3" placeholder="Post an update to the class..."></textarea>
        <div class="ann-composer-toolbar">
            <div class="ann-tools">
                <button class="ec-icon-btn" title="Attachment">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                </button>
                <button class="ec-icon-btn" title="Schedule">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </button>
            </div>
            <button class="ec-btn ec-btn-primary" @onclick="PostAnnouncement">Post Update</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Announcement> Announcements { get; set; } = new();
    private string NewPostContent { get; set; } = "";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
            Announcements = await DataService.GetClassAnnouncementsAsync(ClassId);
    }

    private async Task PostAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(NewPostContent)) return;
        var ann = new Announcement
        {
            ClassId = ClassId,
            AnnouncementAuthorId = "teacher-001",
            AnnouncementTitle = "Update",
            AnnouncementDescription = NewPostContent
        };
        await DataService.PostAnnouncementAsync(ann);
        NewPostContent = "";
        Announcements = await DataService.GetClassAnnouncementsAsync(ClassId);
    }
}
