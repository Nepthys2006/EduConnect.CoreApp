@inject IDataService DataService

<div class="asn-container">
    <div class="asn-header">
        <span class="asn-count">@Assignments.Count assignments</span>
        <button class="ec-btn ec-btn-primary" @onclick="() => ShowAddAssignment = true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Assignment
        </button>
    </div>

    <div class="asn-list">
        @foreach (var a in Assignments)
        {
            <div class="ec-card asn-row">
                <div class="asn-icon @GetTypeColor(a.AssignmentType)">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">@((MarkupString)GetTypeIcon(a.AssignmentType))</svg>
                </div>
                <div class="asn-info">
                    <h4 class="asn-title">@a.AssignmentTitle</h4>
                    <p class="asn-desc">@a.AssignmentDescription</p>
                </div>
                <div class="asn-meta">
                    <span class="asn-due">Due @a.DueDate.ToString("MMM dd")</span>
                    <span class="asn-points">@a.TotalPoints pts</span>
                </div>
                <span class="ec-badge @GetStatusBadge(a.AssignmentStatus)">@a.AssignmentStatus</span>
                <button class="ec-btn ec-btn-sm ec-btn-secondary" @onclick="() => OpenDrawer(a)">View Details</button>
                <button class="ec-icon-btn">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                </button>
            </div>
        }
    </div>
</div>

<!-- Assignment Detail Drawer -->
@if (SelectedAssignment != null)
{
    <div class="ec-drawer-backdrop" @onclick="CloseDrawer"></div>
    <div class="ec-drawer">
        <div class="ec-drawer-header">
            <div>
                <h3>@SelectedAssignment.AssignmentTitle</h3>
                <p style="margin:0;color:var(--color-text-tertiary);font-size:var(--text-sm);">@SelectedAssignment.AssignmentDescription</p>
            </div>
            <button class="ec-icon-btn" @onclick="CloseDrawer">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="ec-drawer-body">
            <h4 style="font-size:var(--text-sm);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-text-tertiary);margin-bottom:var(--space-3);">Submission Bin</h4>
            <table class="ec-table">
                <thead>
                    <tr><th>Student</th><th style="font-family:'JetBrains Mono',monospace;">LRN</th><th>Submitted</th><th>File</th><th>Grade</th></tr>
                </thead>
                <tbody>
                    @foreach (var sub in Submissions)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:var(--space-2);">
                                    <div class="ec-avatar">@CssClassHelpers.GetInitials(sub.Student?.Name)</div>
                                    <span>@sub.Student?.Name</span>
                                </div>
                            </td>
                            <td style="font-family:'JetBrains Mono',monospace;font-size:var(--text-sm);color:var(--color-text-secondary);">@sub.Student?.LearnerReferenceNumber</td>
                            <td>@(sub.SubmittedAt?.ToString("MMM dd") ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(sub.FileName))
                                {
                                    <a href="#" class="prof-link">@sub.FileName</a>
                                }
                                else
                                {
                                    <span class="ec-badge ec-badge-neutral">Missing</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:var(--space-1);">
                                    <input class="ec-input" style="width:60px;text-align:center;height:32px;" type="number" @bind="sub.Score" />
                                    <span style="color:var(--color-text-tertiary);font-size:var(--text-sm);">/ @SelectedAssignment.TotalPoints</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="ec-drawer-footer">
            <button class="ec-btn ec-btn-secondary" @onclick="CloseDrawer">Close</button>
            <button class="ec-btn ec-btn-primary" @onclick="SaveGrades">Save Grades</button>
        </div>
    </div>
}

@if (ShowAddAssignment)
{
    <div class="ec-modal-backdrop" @onclick="() => ShowAddAssignment = false">
        <div class="ec-modal" @onclick:stopPropagation>
            <div class="ec-modal-header"><h3>Add Assignment</h3><button class="ec-icon-btn" @onclick="() => ShowAddAssignment = false"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
            <div class="ec-modal-body">
                <div style="display:flex;flex-direction:column;gap:var(--space-4);">
                    <div><label class="td-label">Title</label><input class="ec-input" type="text" placeholder="Assignment title" /></div>
                    <div><label class="td-label">Description</label><textarea class="ec-input" rows="2" placeholder="Description"></textarea></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);">
                        <div><label class="td-label">Due Date</label><input class="ec-input" type="date" /></div>
                        <div><label class="td-label">Points</label><input class="ec-input" type="number" placeholder="100" /></div>
                    </div>
                </div>
            </div>
            <div class="ec-modal-footer">
                <button class="ec-btn ec-btn-secondary" @onclick="() => ShowAddAssignment = false">Cancel</button>
                <button class="ec-btn ec-btn-primary" @onclick="() => ShowAddAssignment = false">Create</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ClassId { get; set; } = "";
    private List<Assignment> Assignments { get; set; } = new();
    private Assignment? SelectedAssignment { get; set; }
    private List<Submission> Submissions { get; set; } = new();
    private bool ShowAddAssignment { get; set; } = false;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ClassId))
            Assignments = await DataService.GetClassAssignmentsAsync(ClassId);
    }

    private async Task OpenDrawer(Assignment a)
    {
        SelectedAssignment = a;
        Submissions = await DataService.GetAssignmentSubmissionsAsync(a.AssignmentId);
    }
    private void CloseDrawer() => SelectedAssignment = null;

    private async Task SaveGrades()
    {
        foreach (var s in Submissions.Where(s => s.Score.HasValue))
            await DataService.SaveGradeAsync(s.SubmissionId, s.Score);
        CloseDrawer();
    }

    private string GetTypeColor(string type) => type.ToLower() switch
    {
        "code" => "asn-type-blue",
        "quiz" => "asn-type-orange",
        "essay" => "asn-type-purple",
        "project" => "asn-type-teal",
        _ => "asn-type-blue"
    };

    private string GetTypeIcon(string type) => type.ToLower() switch
    {
        "code" => "<polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/>",
        "quiz" => "<path d=\"M9 11l3 3L22 4\"/><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"/>",
        "essay" => "<path d=\"M12 20h9\"/><path d=\"M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z\"/>",
        _ => "<rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/>"
    };

    private string GetStatusBadge(string status) => status.ToLower() switch
    {
        "ongoing" => "ec-badge-primary",
        "pending" => "ec-badge-warning",
        _ => "ec-badge-neutral"
    };
}
